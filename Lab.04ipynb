   "source": [
    "#graficamos el total de pasajeros por clase\n",
    "# Graficamos el total de pasajeros por clase\n",
    "plt.figure(figsize=(8,4)) # Tamaño\n",
    "sns.countplot(df, x=\"pclass\")\n",
    "plt.title(\"Total de pasajeros por clase\")\n",
